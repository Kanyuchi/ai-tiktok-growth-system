# App
APP_ENV=dev
TIMEZONE=Europe/Berlin

# PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tiktok_ai_analytics

# TikTok OAuth + API
TIKTOK_CLIENT_ID=your_client_id
TIKTOK_CLIENT_SECRET=your_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3000/callback
TIKTOK_SCOPES=user.info.basic,video.list,video.insights

# Tokens (set by `exchange-code --save`)
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

TIKTOK_TOKEN_URL=https://open.tiktokapis.com/v2/oauth/token/
TIKTOK_API_BASE_URL=https://open.tiktokapis.com/v2

# Runtime behavior
TIKTOK_AUTO_REFRESH_ON_RUN=true
TIKTOK_REQUEST_TIMEOUT_SECONDS=30
TIKTOK_PAGE_SIZE=20
TIKTOK_MAX_VIDEOS_PER_RUN=200
